{
  "name": "codneo-portfolio",
  "version": "2.0.0",
  "description": "Code Neo — Uddhav Shrimali Portfolio",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/css/style.css -o ./dist/css/style.min.css --minify",
    "dev": "npx tailwindcss -i ./src/css/style.css -o ./dist/css/style.min.css --watch",
    "copy-css": "node -e \"require('fs').copyFileSync('src/css/style.css','dist/css/style.min.css')\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  }
}
